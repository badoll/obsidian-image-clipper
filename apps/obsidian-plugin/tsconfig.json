{
  "compilerOptions": {
    "baseUrl": ".",
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "esModuleInterop": true,
    "target": "es2021",
    "allowJs": true,
    "noImplicitAny": true,
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "importHelpers": true,
    "lib": ["dom", "es2021", "scripthost"],
    "paths": {
      "@obsidian-image-clipper/shared": ["../../packages/shared/src/index.ts"]
    }
  },
  "include": ["**/*.ts", "../../packages/shared/src/**/*.ts"],
}
