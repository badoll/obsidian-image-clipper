{
  "name": "obsidian-image-clipper",
  "version": "0.1.0",
  "description": "Authenticated image localization for Obsidian notes clipped from protected sites, based on Local Images Plus.",
  "main": "../../dist/obsidian-plugin/main.js",
  "scripts": {
    "dev": "rollup --config rollup.config.js -w",
    "build": "rollup --config rollup.config.js --environment BUILD:production",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "version": "json -I -f manifest.json -e \"this.version='$npm_package_version'\" && json -I -f versions.json -e \"this['$npm_package_version']='$(cat manifest.json | json minAppVersion)'\""
  },
  "keywords": [],
  "author": "huhan and Obsidian Image Clipper contributors",
  "license": "MIT",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^24.0.0",
    "@rollup/plugin-json": "^6.0.0",
    "@rollup/plugin-node-resolve": "^15.0.1",
    "@rollup/plugin-typescript": "^11.0.0",
    "@types/async-lock": "^1.3.0",
    "@types/crypto-js": "4.1.1",
    "@types/node": "^14.18.63",
    "@types/safe-regex": "^1.1.2",
    "json": "^11.0.0",
    "obsidian": "^0.16.3",
    "prettier": "^2.4.1",
    "rollup": "^2.32.1",
    "ts-node": "^10.0.0",
    "tslib": "^2.2.0",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "@obsidian-image-clipper/shared": "file:../../packages/shared",
    "async-lock": "^1.4.0",
    "crypto-js": "^4.1.1",
    "file-type": "^21.3.4",
    "findup-sync": "^5.0.0",
    "is-svg": "^6.1.0",
    "moment": "^2.30.1",
    "safe-regex": "^2.1.1"
  },
  "optionalDependencies": {
    "fsevents": "*"
  }
}
